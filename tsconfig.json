{
    "compilerOptions": {
        "outDir": "./dist/",
        "types": ["jest"],
        "noImplicitAny": true,
        "strict": true,
        "module": "ESNext",
        "target": "es6",
        "jsx": "react-jsx",
        "allowJs": true,

        "paths": {
            "@/*": ["./src/*"]
        },
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true
    },
    "ts-node": {
        "compilerOptions": {
            "module": "CommonJS",
            "skipLibCheck": true,
            "types": ["node"]
        }
    },
    "exclude": ["node_modules", "dist", "steiger.config.ts"]
}
